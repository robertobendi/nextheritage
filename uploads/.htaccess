# Uploads must be served, but never executed as PHP. Defense in depth in case
# someone uploads a polyglot or a future field type allows arbitrary files.
<FilesMatch "\.(php|phtml|phar|html|htm|js|cgi|pl|py)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# SVGs can carry <script>. Serving them with a no-script CSP turns a
# malicious upload from stored XSS (running with the site's origin, able to
# act as a logged-in admin) into an inert image. <img> embeds are unaffected.
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    <FilesMatch "\.svg$">
        Header set Content-Security-Policy "default-src 'none'; style-src 'unsafe-inline'"
    </FilesMatch>
</IfModule>
