{% extends '@theme/layout.twig' %}
{% import "@theme/_macros.twig" as ui %}
{% set active = 'missione' %}

{% block title %}Missione — Un ponte tra generazioni · Next Heritage{% endblock %}
{% block description %}La missione di Next Heritage: trasmettere la passione per le auto storiche dalle vecchie alle nuove generazioni in Ticino, con la Federazione Svizzera dei Veicoli Storici.{% endblock %}
{% block head %}
    <meta property="og:title" content="Missione — Un ponte tra generazioni">
    <meta property="og:description" content="Trasmettere la passione per i veicoli storici alle nuove generazioni, evento dopo evento.">
{% endblock %}

{% block content %}
<section class="sec--sm on-dark">
    <div class="wrap">
        <p class="kicker">Chi siamo · Young4Vintage</p>
        <h1 class="display">Un ponte tra<br><em>generazioni</em></h1>
    </div>
</section>

<section class="sec">
    <div class="wrap cols-2">
        <div class="reveal">
            <p class="lede" style="color:var(--inchiostro);">Ogni generazione eredita un patrimonio di conoscenze, valori e passioni che acquista significato solo quando viene condiviso. La vera eredità non consiste nel conservare ciò che abbiamo ricevuto, ma nel renderlo vivo per chi verrà dopo di noi.</p>
            <p class="measure">Favorire l'incontro tra esperienza e innovazione significa creare un dialogo capace di trasformare la memoria in opportunità: così le nuove generazioni possono comprendere, valorizzare e reinterpretare il patrimonio del motorismo con uno sguardo rivolto al futuro.</p>
        </div>
        <figure class="coach reveal">
            <div class="ph ph--tint" style="aspect-ratio:4/3;">
                <img src="/uploads/community.jpg" alt="Genitori, figli e appassionati della comunità Next Heritage riuniti a un raduno" width="640" height="480" loading="lazy">
            </div>
            <figcaption>La comunità · un raduno in Ticino</figcaption>
        </figure>
    </div>
</section>

<hr class="coachline">

<section class="sec">
    <div class="wrap cols-3">
        <div class="reveal">
            <p class="kicker">01 · Eredità</p>
            <h3 style="margin-bottom:.7rem;">Capolavori su ruote</h3>
            <p style="color:var(--inchiostro-2);">L'arte dei veicoli d'epoca si rivela in ogni curva, in ogni dettaglio cromato, in ogni rumore del motore che racconta strade lontane e tempi gloriosi. Un capolavoro mobile dove la meccanica incontra l'estetica.</p>
        </div>
        <div class="reveal">
            <p class="kicker">02 · Rinnovamento</p>
            <h3 style="margin-bottom:.7rem;">Giovani al volante</h3>
            <p style="color:var(--inchiostro-2);">Portiamo le nuove generazioni a guidare la storia, non solo ad ammirarla. Dalle sessioni del Progetto Giovani agli equipaggi genitori-figli del Gottardo, la passione si trasmette mettendosi davvero al volante.</p>
        </div>
        <div class="reveal">
            <p class="kicker">03 · Appartenenza</p>
            <h3 style="margin-bottom:.7rem;">Un gruppo unito</h3>
            <p style="color:var(--inchiostro-2);">Siamo un gruppo unito dalla stessa passione, dove entusiasmo, competenze e visione si incontrano. Insieme diamo vita a progetti ed esperienze che valorizzano i veicoli storici del Ticino.</p>
        </div>
    </div>
</section>

<section class="sec on-dark" id="galleria">
    <div class="wrap">
        <p class="kicker reveal">Galleria</p>
        <h2 class="reveal" style="margin-bottom:2.8rem;">Capolavori su ruote<br>che <em>raccontano il tempo</em></h2>
        <div class="cols-3">
            <figure class="coach reveal" style="background:var(--pino-2);">
                <div class="ph ph--tint" style="aspect-ratio:3/2;">
                    <img src="/uploads/alfa-rear.jpg" alt="Alfa Romeo 6C 2500 storica argento, dettaglio della linea posteriore" width="480" height="320" loading="lazy">
                </div>
                <figcaption>Alfa Romeo 6C · linea Touring</figcaption>
            </figure>
            <figure class="coach reveal" style="background:var(--pino-2);">
                <div class="ph ph--tint" style="aspect-ratio:3/2;">
                    <img src="/uploads/bmw328-race.jpg" alt="BMW 328 storica numero 99 in azione durante una rievocazione" width="480" height="320" loading="lazy">
                </div>
                <figcaption>In gara · spirito Mille Miglia</figcaption>
            </figure>
            <figure class="coach reveal" style="background:var(--pino-2);">
                <div class="ph ph--tint" style="aspect-ratio:3/2;">
                    <img src="/uploads/ceresio.jpg" alt="Veduta storica del Lago di Lugano a Porto Ceresio, teatro dei nostri eventi" width="480" height="320" loading="lazy">
                </div>
                <figcaption>Ceresio · le nostre strade</figcaption>
            </figure>
        </div>
    </div>
</section>

<section class="sec band-avorio2">
    <div class="wrap cols-2" style="align-items:start;">
        <div class="reveal">
            <p class="kicker">Sotto un'unica bandiera</p>
            <h2>Federazione Svizzera<br>dei <em>Veicoli Storici</em></h2>
        </div>
        <div class="reveal">
            <p class="measure">Sostenitori e appassionati uniti sotto un'unica bandiera: la Federazione Svizzera dei Veicoli Storici vi dà voce per promuovere i veicoli storici, trasformando la nostalgia in azione concreta per la conservazione del nostro retaggio automobilistico.</p>
            <p class="swiss-line" style="margin-top:1.4rem;">
                {{ ui.swiss_chip() }}
                Next Heritage · associazione promotrice di Young4Vintage Ticino
            </p>
        </div>
    </div>
</section>

<section class="sec on-dark" style="text-align:center;">
    <div class="wrap" style="max-width:52ch;">
        <p class="kicker reveal" style="justify-content:center;">Vivi e trasmetti la passione</p>
        <h2 class="reveal">Partecipa al <em>progetto</em></h2>
        <p class="lede reveal" style="margin:1.4rem auto 2.2rem;">Vuoi vivere e trasmettere questa passione? Diventa socio e scopri come partecipare insieme a noi.</p>
        <p class="reveal" style="margin:0;"><a class="btn btn--oro" href="/diventa-socio">Diventa socio</a></p>
    </div>
</section>
{% endblock %}
