{% extends '@theme/layout.twig' %}
{% import "@theme/_macros.twig" as ui %}
{% set active = 'socio' %}

{% block title %}Diventa socio — Next Heritage{% endblock %}
{% block description %}Unisciti a Next Heritage come socio o sostenitore e contribuisci a portare le nuove generazioni al volante delle auto storiche in Ticino.{% endblock %}
{% block head %}
    <meta property="og:title" content="Diventa socio — Next Heritage">
    <meta property="og:description" content="Socio o sostenitore: scegli come far parte della comunità Young4Vintage del Ticino.">
{% endblock %}

{% block content %}
<section class="sec--sm on-dark">
    <div class="wrap cols-2">
        <div>
            <p class="kicker">Unisciti alla comunità</p>
            <h1 class="display">Diventa<br><em>socio</em></h1>
            <p class="lede" style="margin-top:1.4rem;">Unisciti al nostro gruppo e contribuisci a preservare il patrimonio culturale del futuro — guidando la storia con noi.</p>
        </div>
        <figure class="coach" style="background:var(--pino-2);">
            <div class="ph ph--tint" style="aspect-ratio:16/10;">
                <img src="/uploads/steering.jpg" alt="Volante e cruscotto di un'auto d'epoca, dettaglio cromato" width="640" height="400" loading="lazy">
            </div>
            <figcaption>Il posto di guida ti aspetta</figcaption>
        </figure>
    </div>
</section>

<section class="sec">
    <div class="wrap">
        <p class="kicker reveal">Due modi per esserci</p>
        <h2 class="reveal" style="margin-bottom:2.8rem;">Scegli il tuo <em>ruolo</em></h2>
        <div class="member-cards">
            <article class="m-card reveal">
                <div>
                    <p class="kicker" style="margin-bottom:.4rem;">Al volante</p>
                    <h3>Socio</h3>
                    <p class="m-note">Per chi vuole partecipare</p>
                    <ul class="m-list">
                        <li>Accesso agli eventi e ai rally 2026</li>
                        <li>Posti negli equipaggi e nel Progetto Giovani</li>
                        <li>Parte attiva della comunità Young4Vintage</li>
                        <li>Aggiornamenti su programmi e iscrizioni</li>
                    </ul>
                </div>
            </article>
            <article class="m-card reveal">
                <div>
                    <p class="kicker" style="margin-bottom:.4rem;">Al fianco</p>
                    <h3>Sostenitore</h3>
                    <p class="m-note">Per chi vuole sostenere</p>
                    <ul class="m-list">
                        <li>Sostieni la missione di Next Heritage</li>
                        <li>Aiuti a costruire il legame tra passato e presente</li>
                        <li>Riconoscimento come sostenitore dell'iniziativa</li>
                        <li>Inviti agli appuntamenti dell'associazione</li>
                    </ul>
                </div>
            </article>
        </div>
    </div>
</section>

<section class="sec band-avorio2">
    <div class="wrap cols-2" style="align-items:start;">
        <div class="reveal">
            <p class="kicker">Richiesta di adesione</p>
            <h2>Compila<br>e <em>invia</em></h2>
            <p class="measure" style="margin-top:1.1rem;">Raccontaci chi sei e come vuoi partecipare. Ti ricontattiamo via e-mail con tutti i dettagli per l'adesione.</p>
            <p class="swiss-line" style="margin-top:1.4rem;">{{ ui.swiss_chip() }} Membri della Federazione Svizzera dei Veicoli Storici</p>
        </div>
        <div class="m-card reveal">
            <div>
                <form class="form-grid" action="mailto:info@nextheritage.ch?subject=Richiesta%20adesione%20Next%20Heritage" method="post" enctype="text/plain">
                    <div class="form-row">
                        <label class="field"><span>Nome</span><input name="nome" type="text" autocomplete="given-name" required></label>
                        <label class="field"><span>Cognome</span><input name="cognome" type="text" autocomplete="family-name"></label>
                    </div>
                    <label class="field"><span>Email</span><input name="email" type="email" autocomplete="email" required></label>
                    <label class="field"><span>Ruolo</span>
                        <select name="ruolo">
                            <option value="Socio">Socio — voglio partecipare</option>
                            <option value="Sostenitore">Sostenitore — voglio sostenere</option>
                        </select>
                    </label>
                    <label class="field"><span>Messaggio</span><textarea name="messaggio" placeholder="Parlaci della tua passione per le auto storiche…"></textarea></label>
                    <input type="text" name="_hp" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;" aria-hidden="true">
                    <button class="btn btn--oro" type="submit">Invia richiesta</button>
                </form>
            </div>
        </div>
    </div>
</section>

<section class="sec--sm">
    <div class="wrap" style="text-align:center;">
        <p class="swiss-line" style="justify-content:center; margin:0;">{{ ui.swiss_chip() }} I tuoi dati restano tra noi — niente spam, solo Next Heritage.</p>
    </div>
</section>
{% endblock %}
