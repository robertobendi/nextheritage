{% extends '@theme/layout.twig' %}

{% block title %}Pagina non trovata — Next Heritage{% endblock %}
{% block description %}La pagina cercata non esiste o è stata spostata. Torna alla home di Next Heritage.{% endblock %}

{% block content %}
<section class="sec on-dark" style="text-align:center;">
    <div class="wrap" style="max-width:60ch;">
        <p class="kicker" style="justify-content:center;">Errore 404</p>
        <h1 class="display">Fuori<br><em>strada</em></h1>
        <p class="lede" style="margin:1.6rem auto 2.4rem;">Questa pagina non esiste, o ha cambiato percorso. Rimettiti in carreggiata.</p>
        <div class="hero-actions" style="justify-content:center; margin-top:0;">
            <a class="btn btn--oro" href="/">Torna alla home</a>
            <a class="btn btn--line" href="/eventi">Vedi gli eventi</a>
        </div>
    </div>
</section>
{% endblock %}
