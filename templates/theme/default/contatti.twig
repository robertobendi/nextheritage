{% extends '@theme/layout.twig' %}
{% import "@theme/_macros.twig" as ui %}
{% set active = 'contatti' %}

{% block title %}Contatti — Next Heritage{% endblock %}
{% block description %}Scrivi a Next Heritage per partecipare agli eventi, diventare socio o ricevere informazioni sul motorismo storico in Ticino. info@nextheritage.ch.{% endblock %}
{% block head %}
    <meta property="og:title" content="Contatti — Next Heritage">
    <meta property="og:description" content="Apri una linea con l'associazione ticinese Young4Vintage. Scrivici via e-mail.">
{% endblock %}

{% block content %}
<section class="sec--sm on-dark">
    <div class="wrap">
        <p class="kicker">Parla con noi</p>
        <h1 class="display">Apriamo<br><em>il garage</em></h1>
    </div>
</section>

<section class="sec">
    <div class="wrap cols-text">
        <div class="reveal">
            <p class="kicker">Scrivici</p>
            <h2 style="margin-bottom:1.1rem;">Vieni a guidare<br><em>con noi</em></h2>
            <p class="measure">I nostri eventi accolgono appassionati e curiosi, offrendo momenti di scoperta e condivisione nel mondo dei veicoli storici. Per maggiori informazioni, per iscriverti o per partecipare al Progetto Giovani, non esitare a contattarci.</p>
            <p style="margin-top:1.8rem;">
                <a class="tlink" href="mailto:info@nextheritage.ch">info@nextheritage.ch</a>
            </p>
            <p class="swiss-line" style="margin-top:1.8rem;">{{ ui.swiss_chip() }} Ticino, Svizzera · Young4Vintage</p>
        </div>
        <div class="m-card reveal">
            <div>
                <form class="form-grid" action="mailto:info@nextheritage.ch?subject=Messaggio%20dal%20sito%20Next%20Heritage" method="post" enctype="text/plain">
                    <label class="field"><span>Nome</span><input name="name" type="text" autocomplete="name" required></label>
                    <label class="field"><span>Email</span><input name="email" type="email" autocomplete="email" required></label>
                    <label class="field"><span>Messaggio</span><textarea name="message" placeholder="Come possiamo aiutarti?" required></textarea></label>
                    <input type="text" name="_hp" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;" aria-hidden="true">
                    <button class="btn btn--oro" type="submit">Invia messaggio</button>
                </form>
            </div>
        </div>
    </div>
</section>

<section class="sec band-avorio2">
    <div class="wrap cols-2">
        <div class="reveal">
            <p class="kicker">Dove corriamo</p>
            <h2>Il Ticino delle<br><em>auto storiche</em></h2>
            <p class="measure" style="margin-top:1.1rem;">Dal Gottardo al Ceresio, da Lugano a Locarno: le nostre strade sono il palcoscenico naturale del motorismo d'epoca. Lugano, Ascona, Giubiasco e Campione d'Italia.</p>
            <p class="swiss-line" style="margin-top:1.4rem;">{{ ui.swiss_chip() }} Federazione Svizzera dei Veicoli Storici</p>
        </div>
        <figure class="coach reveal">
            <div class="ph ph--tint" style="aspect-ratio:16/10;">
                <img src="/uploads/ceresio.jpg" alt="Veduta storica del Lago di Lugano, Ceresio, Ticino" width="640" height="400" loading="lazy">
            </div>
            <figcaption>Il Ceresio · le nostre strade</figcaption>
        </figure>
    </div>
</section>
{% endblock %}
