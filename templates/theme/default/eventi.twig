{% extends '@theme/layout.twig' %}
{% import "@theme/_macros.twig" as ui %}
{% set active = 'eventi' %}

{% block title %}Eventi 2026 — Next Heritage{% endblock %}
{% block description %}Tre rally storici in Ticino nel 2026: Gottardo Classic (21 giugno), Rievocazione di Campione d'Italia (3–6 settembre) e Lugano Classic (17–18 ottobre).{% endblock %}
{% block head %}
    <meta property="og:title" content="Eventi 2026 — Next Heritage">
    <meta property="og:description" content="Gottardo Classic, Rievocazione di Campione d'Italia e Lugano Classic: il calendario delle auto storiche in Ticino.">
{% endblock %}

{% block content %}
<section class="sec--sm on-dark">
    <div class="wrap">
        <p class="kicker">Calendario · Ticino, Svizzera</p>
        <h1 class="display">Stagione <em>2026</em></h1>
        <p class="lede" style="margin-top:1.4rem;">Tre appuntamenti per vivere il motorismo storico da protagonisti, non da spettatori. Date fisse, percorsi reali, posti al volante.</p>
    </div>
</section>

<section class="sec">
    <div class="wrap">
        <article class="plate">
            <div class="reveal">
                <p class="plate-n">Tappa 01 · Ottava edizione</p>
                <h2>Gottardo <em>Classic</em></h2>
                <p class="stamp" style="margin:.5rem 0 1.1rem;">21 giugno</p>
                <p class="measure">L'edizione 2026 sarà ancora più speciale: due equipaggi composti da genitori e figli portano in strada il vero spirito della manifestazione. Un'esperienza che unisce tradizione, condivisione e amore per le auto storiche.</p>
                <ol class="roadbook" aria-label="Percorso Gottardo Classic">
                    <li>Winteler, Giubiasco</li>
                    <li>Golf Club Gerre</li>
                    <li>Ascona</li>
                    <li>Locarno</li>
                    <li>Gottardo Arena</li>
                </ol>
                <a class="btn btn--oro" href="mailto:info@nextheritage.ch?subject=Gottardo%20Classic%202026">Programma &amp; iscrizione</a>
            </div>
            <figure class="coach plate-media reveal">
                <div class="ph ph--tint" style="aspect-ratio:4/3;">
                    <img src="/uploads/bmw328-race.jpg" alt="BMW 328 storica numero 99 in gara su strada di montagna verso il Gottardo" width="640" height="480" loading="lazy">
                </div>
                <figcaption>Verso il Gottardo · N° 99</figcaption>
            </figure>
        </article>
    </div>
</section>

<hr class="coachline">

<section class="sec">
    <div class="wrap">
        <article class="plate plate--flip">
            <div class="reveal">
                <p class="plate-n">Tappa 02 · Kermesse del Ceresio</p>
                <h2>Rievocazione di<br><em>Campione d'Italia</em></h2>
                <p class="stamp" style="margin:.5rem 0 1.1rem;">3–6 settembre</p>
                <p class="measure">Il «circuito più piccolo del mondo» torna in vita tra le strade del Lago di Lugano. Un evento unico per rivivere l'emozione delle grandi corse d'epoca e diventare parte di una leggenda senza tempo.</p>
                <ol class="roadbook" aria-label="Programma Campione d'Italia">
                    <li>Circuito cittadino del Ceresio</li>
                    <li>Sessioni di guida diurne</li>
                    <li>Sessioni di guida notturne</li>
                </ol>
                <div style="border:1px solid var(--oro); padding:1.2rem 1.4rem; margin:0 0 1.6rem; background:var(--bianco-caldo);">
                    <p style="font-family:var(--f-mono); font-size:.7rem; font-weight:600; letter-spacing:.22em; text-transform:uppercase; color:var(--oro-cupo); margin:0 0 .5rem;">Progetto Giovani</p>
                    <p style="margin:0; font-size:1.02rem;">I partecipanti vivono un'esperienza a bordo di autentiche vetture d'epoca, in sessioni di guida diurne e notturne pensate per avvicinare le nuove generazioni al motorismo storico.</p>
                </div>
                <a class="btn btn--oro" href="mailto:info@nextheritage.ch?subject=Campione%20d'Italia%202026">Richiedi informazioni</a>
            </div>
            <figure class="coach plate-media reveal">
                <div class="ph ph--tint" style="aspect-ratio:4/3;">
                    <img src="/uploads/alfa-rear.jpg" alt="Alfa Romeo 6C 2500 storica argento vista posteriore, tipica vettura da rievocazione" width="640" height="480" loading="lazy">
                </div>
                <figcaption>Alfa Romeo 6C · linea Touring</figcaption>
            </figure>
        </article>
    </div>
</section>

<hr class="coachline">

<section class="sec">
    <div class="wrap">
        <article class="plate">
            <div class="reveal">
                <p class="plate-n">Tappa 03 · Due giorni in città</p>
                <h2>Lugano <em>Classic</em></h2>
                <p class="stamp" style="margin:.5rem 0 1.1rem;">17–18 ottobre</p>
                <p class="measure">Le piazze di Lugano si trasformano in un elegante museo a cielo aperto, dove il fascino senza tempo delle auto storiche incontra la bellezza della città. Un suggestivo itinerario tra paesaggi, cultura e tradizioni del Ticino.</p>
                <ol class="roadbook" aria-label="Programma Lugano Classic">
                    <li>Esposizione nelle piazze</li>
                    <li>Tour panoramico nel Ticino</li>
                    <li>Ritrovo &amp; premiazione</li>
                </ol>
                <a class="btn btn--oro" href="mailto:info@nextheritage.ch?subject=Lugano%20Classic%202026">Programma &amp; iscrizione</a>
            </div>
            <figure class="coach plate-media reveal">
                <div class="ph ph--tint" style="aspect-ratio:4/3;">
                    <img src="/uploads/alfa-front.jpg" alt="Alfa Romeo 6C 2500 storica argento vista frontale, esposta come a Lugano Classic" width="640" height="480" loading="lazy">
                </div>
                <figcaption>Museo a cielo aperto · Lugano</figcaption>
            </figure>
        </article>
    </div>
</section>

<section class="sec on-dark" style="text-align:center;">
    <div class="wrap" style="max-width:52ch;">
        <p class="kicker reveal" style="justify-content:center;">Vieni a guidare con noi</p>
        <h2 class="reveal">Un posto al volante<br><em>ti aspetta</em></h2>
        <p class="lede reveal" style="margin:1.4rem auto 2.2rem;">Diventa socio e partecipa agli eventi 2026 come protagonista del motorismo storico ticinese.</p>
        <p class="reveal" style="margin:0;"><a class="btn btn--oro" href="/diventa-socio">Diventa socio</a></p>
    </div>
</section>
{% endblock %}
