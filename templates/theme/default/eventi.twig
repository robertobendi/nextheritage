{% extends '@theme/layout.twig' %}
{% import "@theme/_macros.twig" as ui %}
{% set active = 'eventi' %}

{% block title %}Eventi 2026 — Next Heritage{% endblock %}
{% block description %}Tre rally storici in Ticino nel 2026: Gottardo Classic (21 giugno), Rievocazione di Campione d'Italia (3–6 settembre) e Lugano Classic (17–18 ottobre).{% endblock %}
{% block head %}
    <meta property="og:title" content="Eventi 2026 — Next Heritage">
    <meta property="og:description" content="Gottardo Classic, Rievocazione di Campione d'Italia e Lugano Classic: il calendario delle auto storiche in Ticino.">
{% endblock %}

{% block content %}
<section class="section--sm">
    <div class="wrap">
        <p class="eyebrow">Calendario · Ticino, Svizzera</p>
        <div class="bleed">
            <h1 class="bleed__h">Eventi <span class="accent-word">2026</span></h1>
        </div>
        <p class="hero-sub" style="margin-top:0;">Tre appuntamenti per vivere il motorismo storico da protagonisti, non da spettatori. Date fisse, percorsi reali, posti al volante.</p>
    </div>
</section>

<section class="section">
    <div class="wrap">
        <article class="plate">
            <div>
                <p class="eyebrow">8ª edizione · 21 giugno 2026</p>
                <h2 class="plate-name">Gottardo Classic</h2>
                <p class="date-stamp">21 Giugno</p>
                <p>L'edizione 2026 sarà ancora più speciale: due equipaggi composti da genitori e figli portano in strada il vero spirito della manifestazione. Un'esperienza che unisce tradizione, condivisione e amore per le auto storiche.</p>
                <ol class="route" aria-label="Percorso Gottardo Classic">
                    <li>Winteler, Giubiasco</li>
                    <li>Golf Club Gerre</li>
                    <li>Ascona</li>
                    <li>Locarno</li>
                    <li>Gottardo Arena</li>
                </ol>
                <a class="btn btn--primary" href="mailto:info@nextheritage.ch?subject=Gottardo%20Classic%202026">Programma &amp; iscrizione</a>
            </div>
            <div class="plate__media">
                <figure class="tilt-l" style="margin:0;">
                    <div class="frame frame--photo" style="aspect-ratio:4/3;">
                        <img src="/uploads/bmw328-race.jpg" alt="BMW 328 storica numero 99 in gara su strada di montagna verso il Gottardo" width="640" height="480" loading="lazy">
                    </div>
                </figure>
            </div>
        </article>
    </div>
</section>

<section class="section">
    <div class="wrap">
        <article class="plate">
            <div>
                <p class="eyebrow">Kermesse del Ceresio · 3–6 settembre 2026</p>
                <h2 class="plate-name">Rievocazione di Campione d'Italia</h2>
                <p class="date-stamp">3–6 Set</p>
                <p>Il «circuito più piccolo del mondo» torna in vita tra le strade del Lago di Lugano. Un evento unico per rivivere l'emozione delle grandi corse d'epoca e diventare parte di una leggenda senza tempo.</p>
                <ol class="route" aria-label="Programma Campione d'Italia">
                    <li>Circuito cittadino del Ceresio</li>
                    <li>Sessioni di guida diurne</li>
                    <li>Sessioni di guida notturne</li>
                </ol>
                <div class="giovani-callout">
                    <strong>Progetto Giovani</strong>
                    I partecipanti vivono un'esperienza a bordo di autentiche vetture d'epoca, in sessioni di guida diurne e notturne pensate per avvicinare le nuove generazioni al motorismo storico.
                </div>
                <p style="margin-top:1.5rem;"><a class="btn btn--primary" href="mailto:info@nextheritage.ch?subject=Campione%20d'Italia%202026">Richiedi informazioni</a></p>
            </div>
            <div class="plate__media">
                <figure style="margin:0;">
                    <div class="frame frame--photo" style="aspect-ratio:4/3;">
                        <img src="/uploads/alfa-rear.jpg" alt="Alfa Romeo 6C 2500 storica argento vista posteriore, tipica vettura da rievocazione" width="640" height="480" loading="lazy">
                    </div>
                </figure>
            </div>
        </article>
    </div>
</section>

<section class="section">
    <div class="wrap">
        <article class="plate">
            <div>
                <p class="eyebrow">Due giorni in città · 17–18 ottobre 2026</p>
                <h2 class="plate-name">Lugano Classic</h2>
                <p class="date-stamp">17–18 Ott</p>
                <p>Le piazze di Lugano si trasformano in un elegante museo a cielo aperto, dove il fascino senza tempo delle auto storiche incontra la bellezza della città. Un suggestivo itinerario tra paesaggi, cultura e tradizioni del Ticino.</p>
                <ol class="route" aria-label="Programma Lugano Classic">
                    <li>Esposizione nelle piazze</li>
                    <li>Tour panoramico nel Ticino</li>
                    <li>Ritrovo &amp; premiazione</li>
                </ol>
                <a class="btn btn--primary" href="mailto:info@nextheritage.ch?subject=Lugano%20Classic%202026">Programma &amp; iscrizione</a>
            </div>
            <div class="plate__media">
                <figure style="margin:0;">
                    <div class="frame frame--photo" style="aspect-ratio:4/3;">
                        <img src="/uploads/alfa-front.jpg" alt="Alfa Romeo 6C 2500 storica argento vista frontale, esposta come a Lugano Classic" width="640" height="480" loading="lazy">
                    </div>
                </figure>
            </div>
        </article>
    </div>
</section>

<section class="section band-cta">
    <div class="wrap" style="max-width:46ch;">
        <p class="eyebrow">Vieni a guidare con noi</p>
        <h2>Un posto al volante ti aspetta</h2>
        <p style="color:rgba(244,239,226,.85); margin:1rem 0 2rem;">Diventa socio e partecipa agli eventi 2026 come protagonista del motorismo storico ticinese.</p>
        <a class="btn btn--primary" href="/diventa-socio">Diventa socio</a>
    </div>
</section>
{% endblock %}
